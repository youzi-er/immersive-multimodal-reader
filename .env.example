MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_TEXT_MODEL=MiniMax-M3
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_DEFAULT_VOICE_ID=Chinese (Mandarin)_Lyrical_Voice
AUTH_TOKEN_SECRET=

# Speech pipeline (paragraph-speech)
SPEECH_SKIP_VOICE_DESIGN=false
SPEECH_TTS_CONCURRENCY=3

# MySQL media library
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=immersive_app
MYSQL_PASSWORD=
MYSQL_DATABASE=immersive_reader
MYSQL_CONNECTION_LIMIT=10
MEDIA_STORAGE_ROOT=
